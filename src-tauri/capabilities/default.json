{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "bit.LOCK — minimale Berechtigungen (Principle of Least Privilege)",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "dialog:allow-open",
    "dialog:allow-save",
    "opener:allow-open-path",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/qpdf",
          "sidecar": true,
          "args": [
            "--encrypt",
            { "validator": ".+" },
            { "validator": ".+" },
            "256",
            "--",
            { "validator": ".+" },
            { "validator": ".+" }
          ]
        }
      ]
    },
    "updater:default",
    "process:allow-restart"
  ]
}
