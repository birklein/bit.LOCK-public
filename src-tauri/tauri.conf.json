{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bit.LOCK",
  "version": "0.1.0",
  "identifier": "de.birklein.bit-lock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "bit.LOCK",
        "width": 1280,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost https://github.com https://objects.githubusercontent.com; img-src 'self' data:; font-src 'self' data:",
      "dangerousDisableAssetCspModification": false
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBNzMwNjMyODY1RkYzNUYKUldSZjgxK0dNZ1p6S200ZHZaSlFDbnJTMCsvZlJyQ2MxeW5oVkdlWm11TXRLclh4T3FsNUlraU0K",
      "endpoints": [
        "https://github.com/beeene1/bit.LOCK/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/qpdf"],
    "resources": {
      "binaries/lib*.dylib": "."
    },
    "macOS": {
      "signingIdentity": null
    },
    "windows": {
      "nsis": {
        "languages": ["German"],
        "installMode": "currentUser"
      }
    }
  }
}
